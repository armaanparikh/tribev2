# Required: write-scoped HF token.
# Token needs:
#   - write access to the private dataset (TRIBE_DATASET below)
#   - permission to run HF Jobs in TRIBE_NAMESPACE
#   - acceptance of the meta-llama/Llama-3.2-3B license
#
# SECURITY: /api/upload-url returns this token to the browser so the
# video can be uploaded straight to huggingface.co (Vercel serverless
# functions cap request bodies at 4.5 MB, which is too small for video).
# Use a fine-grained token scoped to ONLY the {TRIBE_NAMESPACE}/{TRIBE_DATASET}
# repo + run HF Jobs in TRIBE_NAMESPACE. Create one at
# https://huggingface.co/settings/tokens.
HF_TOKEN=

# HF user/org that owns the scratch dataset and runs the Jobs.
TRIBE_NAMESPACE=

# Dataset slug under TRIBE_NAMESPACE that stores per-job folders ({job_id}/input.*, preds.npy, overlays, meta.json).
# The dataset is created (private) automatically on first /api/jobs call.
TRIBE_DATASET=tribe-jobs

# HF hardware flavor for the GPU job. Must match a value from `hf jobs hardware list`.
# a10g-small is the recommended minimum for TRIBE v2.
TRIBE_FLAVOR=a10g-large

# Max seconds an HF Job is allowed to run before being canceled.
TRIBE_JOB_TIMEOUT=3600

# Raw URL of app/jobs/tribe_predict.py on GitHub. The uv image fetches this and runs it.
# Defaults to the main branch of armaanparikh/tribev2.
TRIBE_SCRIPT_URL=https://raw.githubusercontent.com/armaanparikh/tribev2/main/app/jobs/tribe_predict.py
